#!/usr/bin/env bash
#
# cplan - Claude Plan + Gemini Execute
#
# Usage:
#   cplan          → Claude Code (plan-only) 열림 → plan 작성 → Gemini 자동 실행
#   cplan -g       → 최근 plan을 Gemini로 실행만
#   cplan -l       → plan 목록 + 상태
#

set -euo pipefail

# ── Config ──────────────────────────────────────────────
PLAN_DIR="docs/superpowers/plans"
LOG_DIR="docs/superpowers/logs"
ENV_FILE="$HOME/.claude/env"
PROFILE_DIR="$HOME/.claude/profiles/plan-only"
# GEMINI_MODEL: 설정 시 GEMINI_FALLBACK_MODELS 무시하고 해당 모델만 단일 시도
GEMINI_FALLBACK_MODELS=(
  "auto-gemini-2.5"
  "gemini-2.5-flash"
  "gemini-2.5-flash-lite"
)

# ── Colors ──────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Functions ───────────────────────────────────────────
log_info()  { echo -e "${BLUE}[cplan]${NC} $*"; }
log_ok()    { echo -e "${GREEN}[cplan]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[cplan]${NC} $*"; }
log_error() { echo -e "${RED}[cplan]${NC} $*"; }

usage() {
  cat <<'EOF'
Usage: cplan [options]

  cplan              Open Claude Code (plan-only) → auto-execute with Gemini
  cplan -g           Execute latest plan with Gemini only
  cplan -g <file>    Execute specific plan with Gemini
  cplan -l           List plans and their status
  cplan -h           Show this help

Flow:
  1. cplan 실행 → Claude Code 열림 (plan-only 모드)
  2. Claude에게 원하는 작업을 설명
  3. Claude가 plan 파일 생성 후 세션 종료
  4. 자동으로 Gemini CLI가 plan 실행

Environment:
  GEMINI_MODEL    특정 모델 고정 시 설정 (기본: auto-gemini-2.5 → gemini-2.5-flash-latest → gemini-2.0-flash 순 폴백)
EOF
}

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    source "$ENV_FILE"
    export ANTHROPIC_AUTH_TOKEN ANTHROPIC_BASE_URL ANTHROPIC_MODEL GEMINI_API_KEY 2>/dev/null || true
  fi
}

ensure_dirs() {
  mkdir -p "$PLAN_DIR" "$LOG_DIR"
}

find_latest_plan() {
  ls -t "$PLAN_DIR"/*.md 2>/dev/null | head -1
}

# ── Capacity error detection ─────────────────────────
is_capacity_error() {
  local log_file="$1"
  grep -qE 'MODEL_CAPACITY_EXHAUSTED|RESOURCE_EXHAUSTED|rateLimitExceeded|"code": 429' \
    "$log_file" 2>/dev/null
}

# ── Phase 2: Gemini executes plan ──────────────────────
run_gemini_execute() {
  local plan_file="$1"
  local base
  base=$(basename "$plan_file" .md)
  local log_file="$LOG_DIR/${base}.log"
  local done_file="$LOG_DIR/${base}.done"

  if [[ ! -f "$plan_file" ]]; then
    log_error "Plan 파일이 존재하지 않음: $plan_file"
    return 1
  fi

  # GEMINI_MODEL 환경 변수가 명시적으로 설정된 경우 단일 모델만 시도 (기존 동작 보존)
  local models=()
  if [[ -n "${GEMINI_MODEL:-}" ]]; then
    models=("${GEMINI_MODEL}")
  else
    models=("${GEMINI_FALLBACK_MODELS[@]}")
  fi

  local total=${#models[@]}
  local attempt=0
  local used_model=""
  local final_exit_code=1

  # 로그 초기화
  : > "$log_file"

  echo ""
  log_info "Phase 2: Gemini CLI 실행"
  log_info "  Plan: $plan_file"
  log_info "  Log:  $log_file"
  echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"
  echo ""

  for model in "${models[@]}"; do
    attempt=$((attempt + 1))
    log_info "${model} 시도 중..."
    {
      echo ""
      echo "[${model}] — $(date '+%Y-%m-%d %H:%M:%S')"
    } >> "$log_file"

    local exit_code=0
    local attempt_out
    attempt_out=$(mktemp)

    # 백그라운드 실행 — 사용량 초과(즉시 반환)와 정상 실행을 조기 감지
    gemini \
      --model "$model" \
      --yolo \
      -p "You are an implementation agent. Read the plan file and execute it step by step.
Check off each task as you complete it. If a step fails, log the error and continue to the next step.

Plan file to read and execute: $plan_file

Start by reading the plan file, then execute each task in order." \
      > "$attempt_out" 2>&1 &
    local gemini_pid=$!

    # 첫 응답 대기 (최대 5초) — 사용량 초과는 거의 즉시 반환됨
    local wait_count=0
    while [[ $wait_count -lt 10 ]] && kill -0 "$gemini_pid" 2>/dev/null; do
      if is_capacity_error "$attempt_out" || [[ -s "$attempt_out" ]]; then
        break
      fi
      sleep 0.5
      wait_count=$((wait_count + 1))
    done

    if is_capacity_error "$attempt_out"; then
      # 사용량 초과 — 즉시 다음 모델로
      kill "$gemini_pid" 2>/dev/null
      wait "$gemini_pid" 2>/dev/null
      cat "$attempt_out" >> "$log_file"
      rm -f "$attempt_out"
      log_warn "⚠ ${model} 사용 불가! (사용량 초과)"
      if [[ $attempt -lt $total ]]; then
        continue
      fi
      break
    fi

    # 정상 실행 감지 — 실시간 스트리밍 시작
    echo ""
    log_ok "✓ ${model} 진입 성공! 작업 진행중!"
    echo ""
    tail -f "$attempt_out" &
    local tail_pid=$!

    wait "$gemini_pid" 2>/dev/null || exit_code=$?
    sleep 0.3
    kill "$tail_pid" 2>/dev/null
    wait "$tail_pid" 2>/dev/null

    cat "$attempt_out" >> "$log_file"
    rm -f "$attempt_out"

    if [[ $exit_code -eq 0 ]]; then
      used_model="$model"
      final_exit_code=0
      break
    fi

    # 용량 오류가 아닌 다른 오류 → 루프 종료
    break
  done

  echo ""
  echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"

  if [[ $final_exit_code -eq 0 ]]; then
    {
      echo ""
      echo "[Done] Model: ${used_model} — $(date '+%Y-%m-%d %H:%M:%S')"
    } >> "$log_file"
    touch "$done_file"
    echo ""
    log_ok "✓ 완료! (Model: ${used_model})"
    log_ok "  Plan: $plan_file"
    log_ok "  Log:  $log_file"
  else
    {
      echo ""
      echo "[Failed] — $(date '+%Y-%m-%d %H:%M:%S')"
    } >> "$log_file"
    log_error "✗ 모든 모델 실패"
    log_info "로그 확인: cat $log_file"
  fi

  return $final_exit_code
}

# ── List plans ──────────────────────────────────────────
list_plans() {
  log_info "Plans in $PLAN_DIR/"
  echo ""
  printf "  ${BOLD}%-50s %s${NC}\n" "PLAN" "STATUS"
  printf "  %-50s %s\n" "──────────────────────────────────────────────────" "──────────"

  local found=false
  for plan in "$PLAN_DIR"/*.md; do
    [[ -f "$plan" ]] || continue
    found=true
    local base
    base=$(basename "$plan" .md)
    local status

    if [[ -f "$LOG_DIR/${base}.done" ]]; then
      status="${GREEN}Done${NC}"
    elif [[ -f "$LOG_DIR/${base}.log" ]]; then
      status="${YELLOW}Running${NC}"
    else
      status="${BLUE}Pending${NC}"
    fi

    printf "  %-50s " "$base"
    echo -e "$status"
  done

  if [[ "$found" == false ]]; then
    echo "  (no plans yet)"
  fi
  echo ""
}

# ── Main ────────────────────────────────────────────────
main() {
  # Parse arguments
  case "${1:-}" in
    -g|--gemini-only)
      load_env
      ensure_dirs
      local target="${2:-}"
      if [[ -z "$target" ]]; then
        target=$(find_latest_plan)
      fi
      if [[ -z "$target" || ! -f "$target" ]]; then
        log_error "Plan 파일 없음: ${target:-$PLAN_DIR/}"
        exit 1
      fi
      log_info "Plan: $target"
      run_gemini_execute "$target"
      exit $?
      ;;
    -l|--list)
      ensure_dirs
      list_plans
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac

  # ── Full flow: Claude interactive → Gemini execute ────

  load_env
  ensure_dirs

  # Snapshot: plan 목록 before
  local before_plans
  before_plans=$(ls -1 "$PLAN_DIR"/*.md 2>/dev/null || true)

  # Phase 1: Claude Code interactive (plan-only)
  log_info "Phase 1: Claude Code (plan-only) 시작..."
  log_info "Claude에게 원하는 작업을 설명하세요. plan 완성 후 /execute-gemini 를 입력하세요."
  echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"
  echo ""

  if [[ ! -f "$PROFILE_DIR/CLAUDE.md" ]]; then
    log_error "plan-only 프로필 없음: $PROFILE_DIR/CLAUDE.md"
    exit 1
  fi

  local system_prompt
  system_prompt="$(cat "$PROFILE_DIR/CLAUDE.md")"

  # 직접 실행 (서브쉘 아님) — stdin/stdout 그대로 터미널에 연결
  command claude \
    --tools "Read,Glob,Grep,Write,Bash(gemini *)" \
    --append-system-prompt "$system_prompt" \
    || true

  echo ""
  echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"

  # 세션 종료 후 미실행 plan 안내
  local after_plans
  after_plans=$(ls -1 "$PLAN_DIR"/*.md 2>/dev/null || true)

  local new_plan
  new_plan=$(comm -13 <(echo "$before_plans" | sort) <(echo "$after_plans" | sort) | head -1)

  if [[ -n "$new_plan" && -f "$new_plan" ]]; then
    log_info "미실행 Plan 감지: $new_plan"
    log_info "Gemini로 실행하려면: cplan -g $new_plan"
  fi
}

main "$@"
